# Server configuration
PORT=3003

# Bybit API Credentials (Optional - can use manual logging instead)
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here
BYBIT_IS_TESTNET=false

# Comma-separated list of account types (e.g. UNIFIED,FUND,SPOT,CONTRACT)
BYBIT_ACCOUNT_TYPES=UNIFIED,FUND
